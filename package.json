{
  "name": "mental-math-master-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "build:qa": "tsc -b && vite build --mode qa",
    "build:prod": "tsc -b && vite build --mode production",
    "ios:add": "npx cap add ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npx cap run ios",
    "ios:build": "npx cap build ios",
    "ios:prepare": "npm run build && npm run ios:sync",
    "ios:prepare:prod": "npm run build:prod && npm run ios:sync",
    "preview:dev": "vite preview --mode development",
    "preview:qa": "vite preview --mode qa",
    "preview:prod": "vite preview --mode production",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "@revenuecat/purchases-js": "^1.22.0",
    "@supabase/supabase-js": "^2.88.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/chart.js": "^2.9.41",
    "axios": "^1.15.1",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.561.0",
    "motion": "^12.23.26",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-infinite-scroll-component": "^6.1.1",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^14.0.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
